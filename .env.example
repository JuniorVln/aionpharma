# ─────────────────────────────────────────────────────────────
#  Aion Pharma — Variáveis de ambiente do backend (NÃO comitar o .env real)
#  Copie este arquivo para ".env" e preencha. Em produção, configure
#  estas mesmas variáveis no painel da Vercel (Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────

# ── Tiny ERP (API v2) ────────────────────────────────────────
# Onde gerar: painel do Tiny → instalar extensão "Token API"
# (Início → Extensões da Olist → Vendas) → Configurações → aba E-commerce → Token API
TINY_TOKEN=

# ── Mercado Pago ─────────────────────────────────────────────
# Onde pegar: https://www.mercadopago.com.br/developers → Suas integrações
# → sua aplicação → Credenciais de produção.
# Use as de TESTE enquanto valida, e troque pelas de produção no lançamento.
MERCADOPAGO_ACCESS_TOKEN=
# Public Key da MESMA aplicação/ambiente do Access Token acima.
# É pública por natureza (vai pro frontend) e é usada pelo Wallet Brick
# para abrir o checkout embutido (modal) dentro do site.
MERCADOPAGO_PUBLIC_KEY=

# ── Melhor Envio (cotação de frete por CEP) ──────────────────
# O Olist/Tiny não cota frete por API — a ETIQUETA sai pelo Olist
# Envios no Tiny, mas a COTAÇÃO no checkout vem do Melhor Envio.
# Onde pegar o token: https://melhorenvio.com.br → conta → Integrações
# → Tokens de API (ou app OAuth). Use o Sandbox enquanto valida.
MELHORENVIO_TOKEN=
# "true" enquanto testa (sandbox.melhorenvio.com.br); "false"/vazio em produção.
MELHORENVIO_SANDBOX=true
# CEP de origem — de onde a loja despacha (só números ou com traço).
MELHORENVIO_FROM_CEP=
# Exigido pela API do Melhor Envio: "Nome do app (email de contato)".
MELHORENVIO_USER_AGENT=Aion Pharma (marketing@tartoff.com.br)

# ── Configuração da loja ─────────────────────────────────────
# URL pública do site (usada nos redirects de retorno do pagamento).
# Ex.: https://aionpharma.vercel.app  (sem barra no final)
SITE_URL=https://aionpharma.vercel.app

# Frete grátis acima deste valor (R$). Deixe 0 para desativar.
FREE_SHIPPING_THRESHOLD=99

# Emitir NF-e automaticamente quando o pagamento for aprovado? (true/false)
# Requer configuração fiscal completa no Tiny (certificado A1 + regime tributário).
# Comece com "false" e ative quando o fiscal estiver pronto.
AUTO_EMIT_NFE=false
